   "source": [
    "q = (np.quantile(X,q=1-0.75))\n",
    "print(q)\n",
    "coll =[]\n",
    "c = 0\n",
    "for x in X:\n",
    "    if x > q:\n",
    "        c+=1\n",
    "        coll.append(x)\n",
    "print(sum(coll)/c)\n"
   ]
